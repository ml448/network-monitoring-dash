# InfluxDB Configuration
INFLUXDB_URL=http://localhost:8086
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=CHANGE-ME-strong-random-password
INFLUXDB_ADMIN_TOKEN=CHANGE-ME-generate-random-token
INFLUXDB_ORG=network-monitoring
INFLUXDB_BUCKET=network-metrics

# Grafana Configuration
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE-ME-strong-random-password

# Backend Configuration
SNMP_COMMUNITY=public
PORT=8000
DEMO_MODE=true
ALLOWED_ORIGINS=http://localhost:3000
SNMP_TIMEOUT=2
SNMP_RETRIES=3
SNMP_POLL_INTERVAL=60

# JWT Authentication
JWT_SECRET_KEY=CHANGE-ME-generate-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

#Rate Limiting Configs
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/minute
RATE_LIMIT_DEVICE=60/minute
RATE_LIMIT_DETAIL=120/minute
RATE_LIMIT_HISTORY=30/minute
RATE_LIMIT_USER=30/minute
RATE_LIMIT_HEALTH=60/minute
RATE_LIMIT_ROOT=60/minute

#SMTP Server Configs
SMTP_HOST=SMTP_SERVER_NAME
SMTP_PORT=587
SMTP_USERNAME=your-email@outlook/gmail.com
SMTP_PASSWORD=your-password-or-app-password
SMTP_USE_TLS=true
ALERT_FROM_EMAIL=your-email@outlook/gmail.com
ALERT_TO_EMAIL=your-email@outlook/gmail.com

# Alert Thresholds
ALERT_CPU_THRESHOLD=80
ALERT_MEMORY_THRESHOLD=85
ALERT_BANDWIDTH_THRESHOLD=100
ALERT_RESPONSE_TIME_THRESHOLD=5000
ALERT_COOLDOWN_TIME=300

#Syslog Config
SYSLOG_ENABLED=true
SYSLOG_PORT= "PORT"
SYSLOG_BUFFER_SIZE= 1000
SYSLOG_SEVERITY_THRESHOLD=3
